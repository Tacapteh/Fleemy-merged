rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isAuth() {
      return request.auth != null && request.auth.uid != null;
    }

    function ownsDoc() {
      return isAuth() && resource.data.userId == request.auth.uid;
    }

    function ownsNewDoc() {
      return isAuth() && request.resource.data.userId == request.auth.uid;
    }

    function isTeamMember(teamId) {
      return isAuth() && (
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
        || exists(/databases/$(database)/documents/teams/$(teamId)/memberships/$(request.auth.uid))
      );
    }

    // ---- Users ----
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ---- Per-user collections (userId field) ----
    match /tasks/{docId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update, delete: if ownsDoc();
    }

    match /events/{docId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update, delete: if ownsDoc();
    }

    match /notes/{docId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update, delete: if ownsDoc();
    }

    match /documents/{docId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update, delete: if ownsDoc();
    }

    match /transactions/{docId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update, delete: if ownsDoc();
    }

    // ---- Clients (supports both userId and user_id) ----
    match /clients/{clientId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || resource.data.user_id == request.auth.uid);
      allow create: if isAuth() && (request.resource.data.userId == request.auth.uid || request.resource.data.user_id == request.auth.uid);
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || resource.data.user_id == request.auth.uid);
      allow delete: if isAuth() && (resource.data.userId == request.auth.uid || resource.data.user_id == request.auth.uid);
    }

    // ---- Teams ----
    match /teams/{teamId} {
      // Any authenticated user can read teams (IDs are not guessable)
      allow get, list: if isAuth();
      // Creator must set themselves as ownerId
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
      // Owner has full control; any member can update the members array (to join)
      allow update: if isAuth() && (
        resource.data.ownerId == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
      );
      allow delete: if isAuth() && resource.data.ownerId == request.auth.uid;

      match /memberships/{uid} {
        allow read: if isAuth() && (request.auth.uid == uid || isTeamMember(teamId));
        allow write: if isAuth() && request.auth.uid == uid;
      }

      match /members/{memberUid} {
        allow read: if isAuth() && (request.auth.uid == memberUid || isTeamMember(teamId));
        allow write: if isAuth() && request.auth.uid == memberUid;

        match /{document=**} {
          allow read: if isAuth() && (request.auth.uid == memberUid || isTeamMember(teamId));
          allow write: if isAuth() && request.auth.uid == memberUid;
        }
      }

      match /teamPlanning/{docId} {
        allow read: if isTeamMember(teamId);
        allow write: if false;
      }
    }

    // ---- Historical events (imported planning) ----
    match /historicalEvents/{docId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update, delete: if ownsDoc();
    }

    // ---- Daily todos ----
    match /dailyTodos/{docId} {
      allow read: if isAuth() && resource.data.user_id == request.auth.uid;
      allow write: if isAuth() && request.resource.data.user_id == request.auth.uid;
    }

    // ---- Notifications ----
    match /notifications/{notificationId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
